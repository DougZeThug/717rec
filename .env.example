# Copy this file to `.env` and fill in real values from your Supabase project
# (Dashboard → Project Settings → API). Never commit your local `.env`.
#
# All variables below are PUBLISHABLE / browser-safe — they ship in the client
# bundle. Access control is enforced server-side by Supabase Row Level Security
# (RLS), not by hiding these values.
#
# NEVER put the Supabase `service_role` key (or any other secret) in a `VITE_*`
# variable or in any frontend `.env`. Vite inlines `VITE_*` values into the
# browser bundle, which would publicly expose the key. Server-only secrets
# belong in Edge Function runtime secrets or Lovable Cloud secrets.

VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-publishable-key"
VITE_SUPABASE_PROJECT_ID="your-project-ref"
