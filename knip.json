{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": ["index.html", "e2e/**/*.spec.ts", "src/lib/mcp/**/*.ts"],
  "project": ["src/**/*.{ts,tsx}"],
  "ignore": ["src/integrations/supabase/types.ts"],
  "ignoreDependencies": ["events"],
  "rules": {
    "exports": "error",
    "types": "error",
    "duplicates": "error",
    "enumMembers": "error"
  }
}
